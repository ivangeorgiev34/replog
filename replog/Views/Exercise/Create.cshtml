@using replog.Models.Exercise
@model CreateExerciseViewModel

@{
    ViewData["Title"] = "Create Exercise";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h4 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create New Exercise</h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold"></label>
                            <input asp-for="Name" class="form-control" placeholder="e.g., Bench Press, Barbell Squat" autofocus />
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter execution form tips or machine settings..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold d-block pb-1 border-bottom">Target Muscle Groups</label>
                            <span class="text-muted small d-block mb-3">Select all that apply to this exercise:</span>

                            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
                                @for (int i = 0; i < Model.MuscleGroups.Count; i++)
                                {
                                    <div class="col">
                                        <div class="form-check p-2 border rounded bg-light hover-shadow transition-all">
                                            <input type="hidden" asp-for="@Model.MuscleGroups[i].Id" />
                                            <input type="hidden" asp-for="@Model.MuscleGroups[i].Name" />

                                            <input type="checkbox" asp-for="@Model.MuscleGroups[i].IsSelected" class="form-check-input ms-0 me-2" id="muscle_@i" />
                                            <label class="form-check-label text-dark fw-medium" for="muscle_@i">
                                                @Model.MuscleGroups[i].Name
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 border-top pt-3">
                            <a asp-controller="Home" asp-action="" class="btn btn-outline-secondary px-4">Cancel</a>
                            <button type="submit" class="btn btn-dark px-4">Save Exercise</button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}