@using replog.Data.Dtos.Workout @* Adjust this namespace to match where your Dtos live *@
@model IEnumerable<WorkoutDto>

@{
    ViewData["Title"] = "My Workout History";
}

<div class="container my-5" style="max-width: 900px;">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h2><i class="bi bi-journal-medical text-primary me-2"></i>Workout History</h2>
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Log New Workout
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card text-center p-5 border-0 shadow-sm bg-light">
            <div class="card-body">
                <i class="bi bi-calendar-x text-muted display-4"></i>
                <h4 class="mt-3 text-dark">No workouts recorded yet</h4>
                <p class="text-muted">Start tracking your fitness journey by logging your first workout today!</p>
                <a href="@Url.Action("Create")" class="btn btn-primary mt-2">Log a Workout</a>
            </div>
        </div>
    }
    else
    {
        @foreach (var workout in Model.OrderByDescending(w => w.Date))
        {
            <div class="card shadow-sm mb-4 border-1">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center p-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-calendar-check me-2 text-info"></i>
                        @workout.Date.ToString("dddd, MMMM dd, yyyy")
                    </h5>
                    <span class="badge bg-secondary">
                        @workout.Date.ToString("t")
                    </span>
                </div>

                <div class="card-body p-4 bg-white">

                    @* Group the sets by Exercise so they aren't scattered sequentially *@
                    @{
                        var groupedExercises = workout.Sets.GroupBy(s => s.Exercise.Name);
                    }

                    <div class="row row-cols-1 g-4">
                        @foreach (var exerciseGroup in groupedExercises)
                        {
                            <div class="col-12 border rounded p-3 bg-light-subtle">
                                <h6 class="text-primary fw-bold mb-3 border-bottom pb-2">
                                    <i class="bi bi-activity me-1"></i> @exerciseGroup.Key
                                </h6>

                                <div class="table-responsive">
                                    <table class="table table-sm table-hover table-borderless mb-0">
                                        <thead class="text-muted small">
                                            <tr>
                                                <th style="width: 15%">Set</th>
                                                <th style="width: 45%">Weight</th>
                                                <th style="width: 40%">Reps</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{
                                                int setCounter = 1;
                                            }
                                            @foreach (var set in exerciseGroup)
                                            {
                                                <tr>
                                                    <td class="fw-bold text-muted">@setCounter</td>
                                                    <td>
                                                        <span class="badge bg-light text-dark border px-2 py-1.5 fs-6">
                                                            @set.Kilograms <span class="small text-muted font-monospace">kg</span>
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-light text-dark border px-2 py-1.5 fs-6">
                                                            @set.Repetitions <span class="small text-muted font-monospace">reps</span>
                                                        </span>
                                                    </td>
                                                </tr>
                                                setCounter++;
                                            }
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        }
                    </div>

                </div>
            </div>
        }
    }
</div>