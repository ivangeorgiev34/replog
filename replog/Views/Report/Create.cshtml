@using replog.Models.Report
@model ReportViewModel

@{
    ViewData["Title"] = "Submit Report";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white p-3">
                    <h4 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Submit a New Report</h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold"></label>
                            <input asp-for="Title" class="form-control" placeholder="Enter a descriptive title..." autofocus />
                            <span asp-validation-for="Title" class="text-danger small mt-1 d-block"></span>
                            <div class="form-text text-muted small">Must be 5–50 characters.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-semibold"></label>
                            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Provide the details of your report here..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                            <div class="form-text text-muted small">Must be 10–200 characters.</div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-send me-1"></i> Send Report
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}