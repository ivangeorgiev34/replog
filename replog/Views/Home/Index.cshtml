@using Microsoft.AspNetCore.Identity
@using replog.Data
@using replog.Models.Home

@model CalendarViewModel
@{
    ViewData["Title"] = "Home Page";
    @inject SignInManager<ApplicationUser> SignInManager
    @inject UserManager<ApplicationUser> UserManager
}

<div class="text-center">
    @if(User.Identity != null && !User.Identity.IsAuthenticated)
    {
        <div class="container my-5 text-center py-5">
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6">

                    <h1 class="mb-3">
                        Welcome to RepLog!
                    </h1>
                    <p class="text-muted mb-4">
                        Ready to track your workouts and smash your fitness goals? Log in or create a free account to get started.
                    </p>

                    <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                        <a href="/Identity/Account/Login" class="btn btn-outline-dark btn-lg px-4">
                            Sign In
                        </a>
                        <a href="/Identity/Account/Register" class="btn btn-primary btn-lg px-4 shadow-sm">
                            Register Account
                        </a>
                    </div>

                </div>
            </div>
        </div>
    }
    else if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
    {
        <partial name="_ReportCards" model="Model.Reports" />
    }
    else if(User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("User"))
    {
        <div class="container my-4">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                <h2><i class="bi bi-calendar3-event text-primary me-2"></i>Workout Tracker</h2>

                <form method="get" class="row g-2 align-items-center">
                    <div class="col-auto">
                        <label for="yearSelect" class="form-label mb-0 fw-bold">Select Year:</label>
                    </div>
                    <div class="col-auto">
                        <select id="yearSelect" name="year" class="form-select" onchange="this.form.submit()">
                            @for (int year = 1990; year <= 2050; year++)
                            {
                                <!option value="@year" @(year == Model.SelectedYear ? "selected" : "")>@year</!option>
                            }
                        </select>
                    </div>
                </form>
            </div>

            <div class="mb-4 d-flex align-items-center gap-3">
                <span class="small text-muted">Legend:</span>
                <div class="d-flex align-items-center gap-1">
                    <span class="badge bg-success rounded-circle p-2" style="width: 12px; height: 12px;"></span>
                    <span class="small">Workout Completed</span>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
                @for (int month = 1; month <= 12; month++)
                {
                    var firstDayOfMonth = new DateTime(Model.SelectedYear, month, 1);
                    var daysInMonth = DateTime.DaysInMonth(Model.SelectedYear, month);
                    var dayOfWeekOffset = (int)firstDayOfMonth.DayOfWeek;

                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 bg-light">
                            <div class="card-body p-3">
                                <h5 class="card-title text-center text-capitalize mb-3 fw-bold text-secondary">
                                    @firstDayOfMonth.ToString("MMMM")
                                </h5>

                                <div class="d-grid text-center fw-semibold text-muted mb-1" style="grid-template-columns: repeat(7, 1fr); font-size: 0.75rem;">
                                    <div>Su</div><div>Mo</div><div>Tu</div><div>We</div><div>Th</div><div>Fr</div><div>Sa</div>
                                </div>

                                <div class="d-grid text-center gap-1" style="grid-template-columns: repeat(7, 1fr); font-size: 0.85rem;">
                                    @for (int i = 0; i < dayOfWeekOffset; i++)
                                    {
                                        <div></div>
                                    }

                                    @for (int day = 1; day <= daysInMonth; day++)
                                    {
                                        var currentDay = new DateTime(Model.SelectedYear, month, day);
                                        var hasWorkout = Model.WorkoutDates
                                        .Any(x => x.Year == currentDay.Year
                                        && x.Month == currentDay.Month
                                        && x.DayOfYear == currentDay.DayOfYear);

                                        <div class="d-flex align-items-center justify-content-center position-relative rounded-circle m-auto"
                                             style="width: 32px; height: 32px;
                                            @(hasWorkout ? "background-color: #d1e7dd; color: #0f5132; font-weight: bold;" : "")"
                                             title="@(hasWorkout ? "Workout completed!" : "")">

                                            @day

                                            @if (hasWorkout)
                                            {
                                                <span class="position-absolute bottom-0 start-50 translate-middle-x bg-success rounded-circle"
                                                      style="width: 5px; height: 5px; margin-bottom: 2px;"></span>
                                            }
                                        </div>
                                    }
                                </div>

                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
